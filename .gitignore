# -----------------------------
.DS_Store
Thumbs.db
Desktop.ini
*.swp
*.swo
*~
.vscode/
.idea/

# -----------------------------
# Python bytecode / packaging
# -----------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
*.dylib
*.egg
*.egg-info/
.eggs/
build/
dist/
pip-wheel-metadata/

