# -----------------------------
.claude/worktrees/
.claude/scheduled_tasks.json
.claude/tmp/
.claude/logs/
.agent/
.agents/

# -----------------------------
# Nested git repos safety
# Ignore nested repo metadata so child repos don't pollute root git state
# -----------------------------
**/.git
**/.git/**
**/.gitmodules

# -----------------------------
# uv local virtualenvs inside subprojects
# -----------------------------
**/.venv/

# -----------------------------
# Local agent guidance docs
