# -----------------------------
.env
.env.*
.venv/
venv/
ENV/
env/
.python-version
.pytest_cache/
.mypy_cache/
.ruff_cache/
.pyre/
.hypothesis/
.tox/
.nox/
.coverage
.coverage.*
htmlcov/
.cache/

# -----------------------------
# Jupyter / notebooks
# -----------------------------
.ipynb_checkpoints/

